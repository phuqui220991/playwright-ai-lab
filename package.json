{
    "name": "playwright-ai-lab",
    "version": "1.0.0",
    "description": "Learning Playwright automation from scratch to advanced using modern AI-assisted development, scalable test architecture, CI/CD, API testing, and best practices for QA engineers",
    "main": "index.js",
    "scripts": {
        "test": "npx playwright test --project=chromium",
        "ci": "npx playwright test --project=chromium --workers=1",
        "flaky": "npx playwright test --project=chromium --repeat-each=20",
        "debug": "npx playwright test --project=chromium --debug",
        "ui": "npx playwright test --project=chromium --ui",
        "smoke": "npx playwright test --grep @Smoke --project=chromium",
        "sanity": "npx playwright test --grep @Sanity --project=chromium",
        "api": "npx playwright test --grep @Api --project=chromium",
        "regression": "npx playwright test --grep @Regression --project=chromium",
        "fullTest": "npx playwright test",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,js,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@faker-js/faker": "^10.4.0",
        "@playwright/test": "^1.60.0",
        "@types/node": "^25.8.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-playwright": "^2.10.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "zod": "^4.4.3"
    }
}
